generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  brand       String?
  price       Float
  stock       Int
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  
  // Contact Info
  customerEmail   String
  emailMeUpdates  Boolean     @default(false)
  
  // Delivery Info
  country         String      @default("Philippines")
  firstName       String
  lastName        String
  address         String
  apartment       String?
  postalCode      String
  city            String
  region          String
  phone           String?
  textMeUpdates   Boolean     @default(false)
  
  // Order financials
  totalAmount     Float
  productCost     Float       @default(0)
  shippingCost    Float       @default(0)
  
  // Fulfillment / Dropshipping
  shippingMethod  String      @default("Standard")
  trackingNo      String?
  shipmentStatus  String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, IN_TRANSIT, DELIVERED, CANCELLED
  
  status          String      @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  payPalReference String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}
